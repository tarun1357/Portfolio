# MySQL / AWS RDS — run: npm run certs:rds-ca
# Prisma’s engine often fails strict CA verify with RDS; use sslaccept=accept_invalid_certs (TLS still on).
# DATABASE_URL="mysql://admin:YOUR_PASSWORD@host.region.rds.amazonaws.com:3306/portfolio?sslaccept=accept_invalid_certs"
DATABASE_URL="mysql://USER:PASSWORD@HOST:PORT/DATABASE?sslaccept=accept_invalid_certs"

# Set to 1 to force `content/*.ts` only (skip Prisma). Useful when DATABASE_URL is a placeholder.
# PORTFOLIO_USE_STATIC_CONTENT=1

# Canonical site URL for metadata / OG (optional in dev — defaults to localhost)
NEXT_PUBLIC_SITE_URL="https://your-domain.vercel.app"

# Contact form → Resend (https://resend.com). Recipient defaults in code if omitted.
RESEND_API_KEY=""
CONTACT_FROM="Portfolio <notifications@your-verified-domain.com>"
CONTACT_TO="you@gmail.com"
