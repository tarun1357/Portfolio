// Portfolio CMS — MySQL (PlanetScale, TiDB Cloud Serverless, or any MySQL 8+)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

/// Single-row profile (id = 1)
model SiteProfile {
  id           Int    @id @default(1)
  name         String
  role         String
  focus        String
  heroHeadline String @map("hero_headline") @db.VarChar(512)
  heroSub      String @map("hero_sub") @db.Text
  githubUrl    String @map("github_url") @db.VarChar(512)
  linkedinUrl  String @map("linkedin_url") @db.VarChar(512)
  emailMailto  String @map("email_mailto") @db.VarChar(512)
  /// Facts for the Gemini-powered “Ask about me” widget (editable in DB).
  chatContext  String? @map("chat_context") @db.Text

  aboutEyebrow     String @default("About") @map("about_eyebrow") @db.VarChar(191)
  aboutTitle       String @map("about_title") @db.VarChar(512)
  aboutDescription String @map("about_description") @db.Text

  unansweredQuestions UnansweredChatQuestion[]
  aboutPillars          AboutPillar[]
  educationEntries      EducationEntry[]

  @@map("site_profile")
}

model AboutPillar {
  id            Int         @id @default(autoincrement())
  siteProfileId Int         @default(1) @map("site_profile_id")
  siteProfile   SiteProfile @relation(fields: [siteProfileId], references: [id], onDelete: Cascade)
  label         String      @db.VarChar(128)
  body          String      @db.Text
  sortOrder     Int         @map("sort_order")

  @@index([siteProfileId])
  @@map("about_pillar")
}

model EducationEntry {
  id            Int         @id @default(autoincrement())
  siteProfileId Int         @default(1) @map("site_profile_id")
  siteProfile   SiteProfile @relation(fields: [siteProfileId], references: [id], onDelete: Cascade)
  institution   String      @db.VarChar(512)
  degree        String      @db.VarChar(512)
  period        String      @db.VarChar(255)
  detail        String      @db.Text
  sortOrder     Int         @map("sort_order")

  @@index([siteProfileId])
  @@map("education_entry")
}

/// Visitor questions the chatbot could not answer from `chat_context` (for your review).
model UnansweredChatQuestion {
  id            Int         @id @default(autoincrement())
  siteProfileId Int         @map("site_profile_id")
  siteProfile   SiteProfile @relation(fields: [siteProfileId], references: [id], onDelete: Cascade)
  questionText  String      @map("question_text") @db.Text
  createdAt     DateTime    @default(now()) @map("created_at")

  @@index([siteProfileId])
  @@map("unanswered_chat_question")
}

model StackGroup {
  id        Int         @id @default(autoincrement())
  title     String
  sortOrder Int         @map("sort_order")
  iconKey   String?     @map("icon_key") @db.VarChar(32)
  items     StackItem[]

  @@map("stack_group")
}

model StackItem {
  id          Int        @id @default(autoincrement())
  groupId     Int        @map("group_id")
  group       StackGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  label       String     @db.VarChar(512)
  sortOrder   Int        @map("sort_order")
  iconUrl     String?    @map("icon_url") @db.VarChar(1024)
  accentColor String?    @map("accent_color") @db.VarChar(32)

  @@index([groupId])
  @@map("stack_item")
}

model ExperienceRole {
  id         Int                   @id @default(autoincrement())
  company    String
  title      String
  location   String
  period     String
  summary    String                @db.Text
  sortOrder  Int                   @map("sort_order")
  highlights ExperienceHighlight[]

  @@map("experience_role")
}

model ExperienceHighlight {
  id        Int               @id @default(autoincrement())
  roleId    Int               @map("role_id")
  role      ExperienceRole    @relation(fields: [roleId], references: [id], onDelete: Cascade)
  title     String
  detail    String            @db.Text
  sortOrder Int               @map("sort_order")
  metrics   HighlightMetric[]

  @@index([roleId])
  @@map("experience_highlight")
}

model HighlightMetric {
  id          Int                 @id @default(autoincrement())
  highlightId Int                 @map("highlight_id")
  highlight   ExperienceHighlight @relation(fields: [highlightId], references: [id], onDelete: Cascade)
  text        String              @db.VarChar(512)
  sortOrder   Int                 @map("sort_order")

  @@index([highlightId])
  @@map("highlight_metric")
}

model Project {
  id          Int                 @id @default(autoincrement())
  name        String
  problem     String              @db.Text
  solution    String              @db.Text
  sortOrder   Int                 @map("sort_order")
  stackTags   ProjectStackTag[]
  impactLines ProjectImpactLine[]
  links       ProjectLink[]

  @@map("project")
}

model ProjectStackTag {
  id        Int     @id @default(autoincrement())
  projectId Int     @map("project_id")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tag       String  @db.VarChar(512)
  sortOrder Int     @map("sort_order")

  @@index([projectId])
  @@map("project_stack_tag")
}

model ProjectImpactLine {
  id        Int     @id @default(autoincrement())
  projectId Int     @map("project_id")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  line      String  @db.Text
  sortOrder Int     @map("sort_order")

  @@index([projectId])
  @@map("project_impact_line")
}

model ProjectLink {
  id        Int     @id @default(autoincrement())
  projectId Int     @map("project_id")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  label     String  @db.VarChar(255)
  href      String  @db.VarChar(1024)
  sortOrder Int     @map("sort_order")

  @@index([projectId])
  @@map("project_link")
}

model SystemDesignCard {
  id        Int    @id @default(autoincrement())
  topic     String
  angle     String @db.Text
  sortOrder Int    @map("sort_order")

  @@map("system_design_card")
}

model Achievement {
  id        Int    @id @default(autoincrement())
  title     String
  detail    String
  tone      String @db.Text
  sortOrder Int    @map("sort_order")

  @@map("achievement")
}
